# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000

# ============================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=homefind_db
DB_USER=postgres
DB_PASSWORD=your_password

# ============================================
# APPLICATION URLS
# ============================================
FRONTEND_URL=http://localhost:5175
BACKEND_URL=http://localhost:5000

# ============================================
# EMAIL CONFIGURATION (Nodemailer)
# ============================================
# For Gmail: smtp.gmail.com
# For Outlook: smtp-mail.outlook.com
# For SendGrid: smtp.sendgrid.net
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=michellechitsaka6@gmail.com
SMTP_PASS=fbpxeflizchvlrhx
SMTP_FROM=michellechitsaka6@gmail.com

# ============================================
# FRONTEND ENVIRONMENT VARIABLES (VITE_ prefixed)
# These are exposed to the browser
# ============================================
VITE_API_URL=http://localhost:5000
VITE_APP_NAME=HomeFind SU
VITE_APP_VERSION=1.0.0

# ============================================
# JWT/AUTH CONFIGURATION (Optional)
# ============================================
# JWT_SECRET=your-super-secret-jwt-key
# JWT_EXPIRES_IN=7d
# MAGIC_LINK_EXPIRY=900000 # 15 minutes in milliseconds

# ============================================
# RATE LIMITING (Optional)
# ============================================
# RATE_LIMIT_WINDOW=900000 # 15 minutes
# RATE_LIMIT_MAX_REQUESTS=5

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=development